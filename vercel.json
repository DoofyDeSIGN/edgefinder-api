{
  "functions": {
    "odds.js": { "maxDuration": 30 },
    "scores.js": { "maxDuration": 30 },
    "injuries.js": { "maxDuration": 30 },
    "props.js": { "maxDuration": 30 },
    "betting.js": { "maxDuration": 30 }
  },
  "routes": [
    { "src": "/api/odds", "dest": "/odds.js" },
    { "src": "/api/scores", "dest": "/scores.js" },
    { "src": "/api/injuries", "dest": "/injuries.js" },
    { "src": "/api/props", "dest": "/props.js" },
    { "src": "/api/betting", "dest": "/betting.js" }
  ],
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "*" },
        { "key": "Access-Control-Allow-Methods", "value": "GET, OPTIONS" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type" }
      ]
    }
  ]
}
